server:
  host: 0.0.0.0
  port: 8080

auth:
  # Scoped keys are mandatory. Values are loaded from env vars and compared in constant time.
  # Give callers the smallest scope set they need.
  scoped_keys:
    - key_id: read
      env: AI_BRIDGE_READ_KEY
      scopes: [read]
    - key_id: submit
      env: AI_BRIDGE_SUBMIT_KEY
      scopes: [read, submit, cancel]
    - key_id: admin
      env: AI_BRIDGE_ADMIN_KEY
      scopes: [read, submit, cancel, admin]

state:
  sqlite_path: /app/data/tasks.sqlite3

logging:
  level: INFO
  file_path: /app/logs/bridge.log

audit:
  enabled: true
  file_path: /app/logs/audit.jsonl

metrics:
  # Prometheus histogram buckets for ai_bridge_worker_call_seconds.
  worker_call_seconds_buckets: [0.1, 0.25, 0.5, 1.0, 2.5, 5.0, 10.0, 30.0, 60.0]

circuit_breaker:
  failure_threshold: 3
  recovery_seconds: 30

recovery:
  # manual | idempotent | always. Safe default replays only idempotent tasks.
  policy: idempotent
  delay_seconds: 0

limits:
  global_pending_tasks: 1000
  global_active_tasks: 100
  per_worker_pending_tasks: 100
  per_worker_active_tasks: 2
  sync_active_tasks: 100

compat:
  # Dangerous migration-only escape hatch. Keep false for production.
  allow_implicit_root_filesystem: false

workers:
  - worker_id: bob
    display_name: Bob Worker
    endpoint_url: http://mock-worker:9000
    auth_type: bearer
    secret_env: BOB_WORKER_API_KEY
    model_name: local-worker
    default_system_prompt: "You are a concise worker."
    capabilities:
      - heavy software engineering
      - secure coding practices
      - automated script generation
      - refactoring messy technical files
      - system infrastructure design
    description: "Systems Architect / Lead Software Engineer / DevOps Automation"
    filesystem:
      # Deny-all unless read/write roots are explicitly listed.
      read: ["/workspace", "/shared"]
      write: ["/workspace"]
      # Set true when the bridge and worker share the same filesystem namespace.
      # Canonical mode resolves symlinks and rejects nonexistent requested working directories before dispatch.
      canonicalize: false
    allowed_modes: [sync, async]
    timeout_limits:
      sync_seconds: 15
      async_seconds: 120
    max_concurrent_tasks: 2
